{
  "name": "@overlink/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:content && npm run build:background",
    "build:content": "vite build --config vite.content.config.ts",
    "build:background": "vite build --config vite.background.config.ts",
    "dev": "concurrently \"npm run build:content -- --watch\" \"npm run build:background -- --watch\""
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "concurrently": "^9.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-static-copy": "^2.0.0"
  }
}
