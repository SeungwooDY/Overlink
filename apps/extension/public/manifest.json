{
  "manifest_version": 3,
  "name": "Overlink Meet Validator",
  "version": "0.1.0",
  "description": "Phase 1 feasibility validator for Google Meet slide URL extraction.",
  "permissions": [],
  "host_permissions": ["https://meet.google.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
